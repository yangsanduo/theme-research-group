@article{liEpimediumPolysaccharidesMitigates2024,
 abstract = {<b>Background</b><br/><br/><i>Porphyromonas gingivalis</i> (Pg), a key pathogen in periodontitis, is implicated in various systemic diseases such as pancreatic cancer and Alzheimer's disease. However, as a periodontal pathogen that can directly enter the lower gastrointestinal tract via saliva, its potential impact on the gut microbiome, intestinal inflammation, and its underlying mechanisms remains largely elusive.<br/><br/><b>Results</b><br/><br/>Here, we observed that oral administration of Pg exacerbates intestinal inflammation in mice by inducing gut microbiome dysbiosis, increasing Th17 cells and the release of pro-inflammatory cytokines. Inhibition of Th17 activity with GSK805 or an anti-IL-17A blocking antibody mitigated this inflammatory response, highlighting the mediating role of Th17 cells. Gingipains, the virulence factors of Pg, played a crucial role in this process. Sequential knockout of gingipain genes revealed a gradual reduction in inflammatory phenotypes, with statistically significant alleviation observed when all three gingipain genes were deleted. Co-housing experiments showed that gut microbiota remodeling effectively protected against Th17-driven inflammatory response. Furthermore, immunization with inactivated Pg effectively prevented gut microbiome dysbiosis and Th17 cell-mediated inflammation.<br/><br/><b>Conclusion</b><br/><br/>Our findings suggest that Pg may exacerbate intestinal inflammation, potentially via its gingipain virulence proteases, which are linked to gut microbiota dysbiosis and enhanced Th17-mediated immune responses. These results suggest that gingipains could be promising targets for further investigation in Pg-associated intestinal disorders.},
 author = {Li, Ming and Qu, Ru and Li, Ping and Mo, Xuan and Liu, Juan and Dong, Biao and Liu, Liting and Xu, Zhenjiang Zech},
 copyright = {All rights reserved},
 doi = {10.1016/j.ijbiomac.2024.134203},
 file = {/Users/zech/Zotero/storage/UWBS5IFX/2024-Li_et_al-Epimedium_polysaccharides_mitigates_iPorphyromonas_gingivalis-i-exacerbated.pdf},
 issn = {0141-8130},
 journal = {International Journal of Biological Macromolecules},
 month = {October},
 pages = {134203},
 title = {Epimedium Polysaccharides Mitigates <i>Porphyromonas gingivalis</i>-Exacerbated Intestinal Inflammation by Suppressing the Th17 Pathway and Modulating the Gut Microbiota},
 urldate = {2024-08-13},
 volume = {278},
 year = {2024}
}
