@article{caussyGutMicrobiomeSignature2019,
 abstract = {The presence of cirrhosis in nonalcoholic-fatty-liver-disease (NAFLD) is the most important predictor of liver-related mortality. Limited data exist concerning the diagnostic accuracy of gut-microbiome-derived signatures for detecting NAFLD-cirrhosis. Here we report 16S gut-microbiome compositions of 203 uniquely well-characterized participants from a prospective twin and family cohort, including 98 probands encompassing the entire spectrum of NAFLD and 105 of their first-degree relatives, assessed by advanced magnetic-resonance-imaging. We show strong familial correlation of gut-microbiome profiles, driven by shared housing. We report a panel of 30 features, including 27 bacterial features with discriminatory ability to detect NAFLD-cirrhosis using a Random Forest classifier model. In a derivation cohort of probands, the model has a robust diagnostic accuracy (AUROC of 0.92) for detecting NAFLD-cirrhosis, confirmed in a validation cohort of relatives of proband with NAFLD-cirrhosis (AUROC of 0.87). This study provides evidence for a fecal-microbiome-derived signature to detect NAFLD-cirrhosis.},
 annotation = {00000},
 author = {Caussy, Cyrielle and Tripathi, Anupriya and Humphrey, Greg and Bassirian, Shirin and Singh, Seema and Faulkner, Claire and Bettencourt, Ricki and Rizo, Emily and Richards, Lisa and Xu, Zhenjiang Zech and Downes, Michael R. and Evans, Ronald M. and Brenner, David A. and Sirlin, Claude B. and Knight, Rob and Loomba, Rohit},
 copyright = {2019 The Author(s)},
 doi = {10.1038/s41467-019-09455-9},
 file = {/Users/zech/Zotero/storage/73KBGC3J/2019-Caussy_et_al-A_gut_microbiome_signature_for_cirrhosis_due_to_nonalcoholic_fatty_liver_disease.pdf},
 issn = {2041-1723},
 journal = {Nature Communications},
 langid = {english},
 month = {March},
 number = {1},
 pages = {1406},
 title = {A Gut Microbiome Signature for Cirrhosis Due to Nonalcoholic Fatty Liver Disease},
 urldate = {2019-04-02},
 volume = {10},
 year = {2019}
}
