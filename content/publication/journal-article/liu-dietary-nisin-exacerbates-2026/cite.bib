@article{liuDietaryNisinExacerbates2026,
 abstract = {Diabetic vascular complications (DVCs) are a major cause of morbidity in diabetes, with gut microbiota dysbiosis emerging as an important contributor. This study investigates the impact of nisin, a widely used food preservative, on DVCs using a zebrafish model. We found that nisin exacerbates diabetic vascular pathology in zebrafish through gut microbiota-dependent mechanisms. Nisin treatment induced dysbiosis with enrichment of Gram-negative pathogens and intestinal barrier disruption. Concurrently, it elevated systemic oxidative stress and pro-inflammatory cytokines, accompanied by NF-&kappa;B pathway activation. Germ-free zebrafish experiments confirmed the gut microbiota's essential role in nisin-induced vascular injury. Pharmacological inhibition of NF-&kappa;B reversed nisin's effects, restoring endothelial function and hemodynamics. Our findings reveal a previously unrecognized risk of nisin consumption in diabetic individuals and highlight the gut-vascular axis as a therapeutic target for DVCs.},
 author = {Liu, Liting and Huang, Yong and Xu, Huan and Sun, Yifan and Xu, Zhenjiang Zech and Huang, Xiaochang},
 doi = {10.1016/j.ecoenv.2025.119638},
 file = {/Users/zech/Zotero/storage/W4RPC4KS/2026-Liu_et_al.-Dietary_nisin_exacerbates_diabetic_vascular_complications_through_gut_microbiota_modulation_and_NF-κ.pdf},
 issn = {0147-6513},
 journal = {Ecotoxicology and Environmental Safety},
 keywords = {Diabetic vascular complications,Gut microbiota,Inflammation,NF-B,Nisin,Oxidative stress,Zebrafish},
 month = {January},
 pages = {119638},
 title = {Dietary Nisin Exacerbates Diabetic Vascular Complications through Gut Microbiota Modulation and NF-&kappa;B Signaling},
 urldate = {2026-01-08},
 volume = {309},
 year = {2026}
}
